# Copy this file to .env.local and fill in real values.
# .env.local is already git-ignored.

# From Supabase: Project Settings > API. Both are shipped in the browser
# bundle. NOTE: with this app's open access policies, the anon key grants
# full read/write on all data — there is no authentication of any kind.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
