# Copy this file to .env.local and fill in real values.
# .env.local is already git-ignored — never commit real keys.

# From Supabase: Project Settings > API. These two are safe to expose to the
# browser (the anon key is designed for that; RLS protects the data).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only secrets — NO NEXT_PUBLIC_ prefix, so they never reach the
# browser bundle. Read exclusively by app/api/gate/route.ts.
#
# APP_PASSWORD: the single password you type on the login screen. Pick
# anything; it doesn't have to match the Supabase account password.
APP_PASSWORD=your-gate-password

# The one Supabase account's credentials (created in the Supabase dashboard:
# Authentication > Users > Add user). The server signs in with these after
# the gate password checks out.
APP_SUPABASE_EMAIL=you@example.com
APP_SUPABASE_PASSWORD=your-account-password
