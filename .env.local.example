# Copy this file to .env.local and fill in real values.
# .env.local is already git-ignored — never commit real keys.

# From Supabase: Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Single-user auto-login — no login screen. Create this one account directly
# in Supabase (Authentication > Users > Add user), then put the same
# email/password here so the app can sign in with it automatically.
NEXT_PUBLIC_APP_EMAIL=you@example.com
NEXT_PUBLIC_APP_PASSWORD=your-account-password
